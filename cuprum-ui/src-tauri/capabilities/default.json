{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capabilities for app windows",
  "windows": ["main", "add-design", "inspector:*"],
  "permissions": [
    "core:default",
    "dialog:default",
    "core:window:allow-set-title",
    "core:window:allow-close",
    "updater:default",
    "process:allow-restart"
  ]
}
