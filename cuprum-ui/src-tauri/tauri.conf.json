{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cuprum",
  "mainBinaryName": "Cuprum",
  "version": "0.5.0",
  "identifier": "dev.cuprum.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Cuprum CAM",
        "width": 1320,
        "height": 860,
        "minWidth": 960,
        "minHeight": 620,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": [
          "cu",
          "cuprum"
        ],
        "name": "Cuprum project",
        "description": "Cuprum CAM project",
        "role": "Editor"
      }
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/fixcik/cuprum/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU0M0U0RTEzRTlEN0RCODUKUldTRjI5ZnBFMDQrVkNDZWRGeU1UeEpJNFg2c3prbTZCQmZ3bHZ1eHpFSU5mMVo5c1FBOGFIN2cK"
    }
  }
}
