{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cuprum",
  "mainBinaryName": "Cuprum",
  "version": "0.1.0",
  "identifier": "dev.cuprum.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Cuprum CAM",
        "width": 1320,
        "height": 860,
        "minWidth": 960,
        "minHeight": 620,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
